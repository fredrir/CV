\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/layout}[2026/05/12 v2.1 CV layout]

\RequirePackage[
  a4paper,
  left   = 1.5cm,
  right  = 1.5cm,
  top    = 1.1cm,
  bottom = 1.3cm,
]{geometry}

\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{enumitem}
\RequirePackage{tikz}
\RequirePackage{graphicx}
\RequirePackage{fancyhdr}
\RequirePackage{needspace}

\RequirePackage{hyperref}
\hypersetup{
  colorlinks = true,
  urlcolor   = cvink,
  linkcolor  = cvink,
  citecolor  = cvink,
  pdftitle   = {CV - Fredrik Carsten Hansteen},
  pdfauthor  = {Fredrik Carsten Hansteen},
}

\RequirePackage{lastpage}

\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\linespread{1.05}

\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyfoot[R]{\small\color{cvmuted}\enor{p.~\thepage~of~\pageref{LastPage}}{s.~\thepage~av~\pageref{LastPage}}}

\setlist{nosep}
\setlist[itemize]{
  label       = {\textbullet},
  leftmargin  = 1.8em,
  itemsep     = \cvspacebullet,
  topsep      = \cvspacebullet,
  parsep      = 0pt,
}

\endinput
