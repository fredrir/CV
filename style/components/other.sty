\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/components/other}[2026/05/12 v1.2 CV other experience]

% #1 = role title, #2 = organisation, #3 = date range, #4 = description
\newcommand{\cvother}[4]{%
  \needspace{8\baselineskip}%
  \vspace{\cvspaceentry}%
  \par\noindent
  {\cvfontentry\color{cvink}{\bfseries #1}\cv@bar{\itshape #2}\hfill}%
  \hfill\cvdate{#3}\par
  \vspace{\cvspacebullet}%
  \begin{cvbullets}
    \item #4%
  \end{cvbullets}%
}

\endinput
