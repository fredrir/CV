\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/components/other}[2026/05/12 v1.2 CV other experience]

% #1 = role title, #2 = organisation, #3 = date range, #4 = description
\newcommand{\cvother}[4]{%
  \cv@entrypre
  \cv@row{#1}{#2}{#3}%
  \vspace{\cvspacebullet}%
  \begin{cvbullets}
    \item #4%
  \end{cvbullets}%
}

\endinput
