\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/components/selected}[2026/05/12 v1.2 CV selected experience]

% #1 = project/role title, #2 = subtitle or organisation, #3 = date range
\newcommand{\cvselected}[3]{%
  \cv@entrypre
  \cv@row{#1}{#2}{#3}%
  \nopagebreak%
}

% #1 = comma-separated technology stack
\newcommand{\cvtech}[1]{%
  \nopagebreak
  \par\noindent\hspace*{1.8em}{\cvfontbody\itshape\color{cvmuted}#1}\par
  \nopagebreak
  \vspace{\cvspacebullet}%
}

\endinput
