% #1 = degree title, #2 = institution, #3 = location, #4 = date range
\newcommand{\cveduentry}[4]{%
  \vspace{5pt}%
  \par\noindent
  {\cvfontentry\bfseries\color{cvink}#1}\hfill\cvdate{#4}\par
  {\color{cvink}#2\cv@bar #3}\par
  \vspace{6pt}%
}

\endinput
