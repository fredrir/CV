\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/components/section}[2026/05/12 v1.1 CV section heading]

% #1 = section title (uppercased automatically)
\newcommand{\cvsection}[1]{%
  \vspace{\cvspacesection}\par
  {\color{cvsoft}\rule{\linewidth}{0.5pt}}\par
  \vspace{3pt}
  {\cvfontsection\bfseries\color{cvink}\MakeUppercase{#1}\par}%
  \vspace{\cvspaceheader}%
}

\endinput
