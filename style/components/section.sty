\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/components/section}[2026/05/12 v1.3 CV section heading]

% #1 = section title (uppercased automatically)
\newcommand{\cvsection}[1]{%
  \vspace{\cvspacesectiontop}\par\noindent
  {\cvfontsection\bfseries\color{cvink}\MakeUppercase{#1}\par}%
  \vspace{\cvspacesectionrule}%
  {\color{cvink}\hrule height 0.75pt}%
  \vspace{\cvspacesectionbottom}%
}

\endinput
