\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/components/subentry}[2026/05/12 v2.2 CV multi-role sub-entry]

\newif\ifcv@firstitem

% Date-group block
% #1 = start date, #2 = end date
\newenvironment{cvsubentryblock}[2]{%
  \gdef\cv@groupstart{#1}%
  \gdef\cv@groupend{#2}%
  \cv@firstitemtrue%
}{}

% Item inside a cvsubentryblock
% #1 = course or project name, #2 = position percentage
\newcommand{\cvsubentryitem}[2]{%
  \par\noindent
  \hspace{1.0em}\ifcv@firstitem\textbullet\else\phantom{\textbullet}\fi\enspace
  #1~(#2)%
  \ifcv@firstitem
    \hfill\cvdate{\cv@groupstart\enspace--\enspace\cv@groupend}%
    \global\cv@firstitemfalse%
  \fi
  \par\vspace{\cvspacebullet}%
}

% Short centered rule separator between consecutive date groups.
% Top padding subtracts cvspacebullet to compensate for the trailing space
% already added by the last \cvsubentryitem, achieving equal visual spacing.
\newcommand{\cvsubgroupsep}{%
  \vspace{\dimexpr\cvspacesubgroup - \cvspacebullet\relax}%
  \vspace{\cvspacesubgroup}%
}

\endinput
