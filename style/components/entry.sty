\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/components/entry}[2026/05/12 v1.1 CV experience entry]


% #1 = role/title, #2 = organisation, #3 = location, #4 = date range (empty when followed by \cvsubentryblock)
\newcommand{\cventry}[4]{%
  \cv@entrypre
  {\cvfontentry\color{cvink}{\bfseries #1}\cv@bar #2\cv@bar #3\hfill}%
  \cvdate{#4}\par
  \ifblank{#4}{\vspace{\cvspaceheader}}{\vspace{\cvspacebullet}}%
}

\newenvironment{cvbullets}{%
  \nopagebreak
  \begin{itemize}%
    }{%
  \end{itemize}\vspace{\cvspaceentry}%
}

\endinput
