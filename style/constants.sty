\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/constants}[2026/05/12 v2.0 CV constants]

\newcommand{\cvfontname}{\fontsize{20}{24}\selectfont}
\newcommand{\cvfontsection}{\fontsize{12}{14}\selectfont}
\newcommand{\cvfontentry}{\fontsize{11}{13}\selectfont}

% Vertical spacing scale
\newlength{\cvspaceheader}   \setlength{\cvspaceheader}{5pt} % after section title (UTDANNING, ARBEIDSERFARING …)
\newlength{\cvspacesection}  \setlength{\cvspacesection}{3pt} % between sections, before the rule line
\newlength{\cvspaceentry}    \setlength{\cvspaceentry}{6pt} % between entries (jobs, education items, selected projects)
\newlength{\cvspacebullet}   \setlength{\cvspacebullet}{1pt} % between bullet points, skill lines, sub-entry items
\newlength{\cvspacesubgroup} \setlength{\cvspacesubgroup}{3pt} % between sub-entry date groups (kept equal to cvspacebullet)

\endinput
